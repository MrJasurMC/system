# Copy this file to .env and fill in real values before running.
# cp .env.example .env

NODE_ENV=development
PORT=4000

# --- Database (Postgres via TypeORM) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=limitless
DB_PASSWORD=change_me
DB_NAME=project_limitless
DB_SSL=false

# --- Redis (Socket.io adapter fan-out) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Security ---
CORS_ORIGIN=http://localhost:5173

# --- Rate limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- AI Meal Scanner (Settings > nutrition-scan) ---
# Get a key at https://console.anthropic.com — required for the "Scan Meal" feature only.
ANTHROPIC_API_KEY=
