# Copy to .env for local overrides, or set these in your host's dashboard
# (e.g. Netlify: Site settings → Environment variables) for production.
#
# Leave both unset for local dev — vite.config.ts already proxies /api and
# /socket.io to http://localhost:4000.

# Full URL to your deployed backend's API, INCLUDING the /api prefix.
# VITE_API_URL=https://your-backend.up.railway.app/api

# Only needed if your WebSocket origin differs from VITE_API_URL's origin
# (rare — usually leave this unset and it's derived automatically).
# VITE_SOCKET_URL=https://your-backend.up.railway.app
